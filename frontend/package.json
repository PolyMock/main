{
	"name": "polymock-frontend",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"dev:wrangler": "npm run build && wrangler pages dev .svelte-kit/cloudflare --compatibility-date=2024-01-01 --port=8788 --live-reload",
		"dev:watch": "vite build --watch",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch"
	},
	"devDependencies": {
		"@sveltejs/adapter-auto": "^6.1.0",
		"@sveltejs/adapter-cloudflare": "^7.2.4",
		"@sveltejs/kit": "^2.43.2",
		"@sveltejs/vite-plugin-svelte": "^6.2.0",
		"svelte": "^5.39.5",
		"svelte-check": "^4.3.2",
		"typescript": "^5.9.2",
		"vite": "^7.1.7",
		"vite-plugin-node-polyfills": "^0.24.0"
	},
	"dependencies": {
		"@coral-xyz/anchor": "^0.32.1",
		"@magicblock-labs/ephemeral-rollups-sdk": "^0.6.5",
		"@pythnetwork/hermes-client": "^2.0.0",
		"@solana/wallet-adapter-base": "^0.9.27",
		"@solana/wallet-adapter-wallets": "^0.19.37",
		"@solana/web3.js": "^1.98.4",
		"@supabase/supabase-js": "^2.99.0",
		"@web3auth/base": "^9.7.0",
		"@web3auth/modal": "^9.7.0",
		"@web3auth/solana-provider": "^9.7.0",
		"@xterm/addon-fit": "^0.11.0",
		"@xterm/xterm": "^6.0.0",
		"axios": "^1.12.2",
		"lightweight-charts": "^5.1.0",
		"react": "^18.3.1",
		"react-dom": "^18.3.1"
	}
}
